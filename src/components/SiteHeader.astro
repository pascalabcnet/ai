---
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
	config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const navItems = [
	{ label: 'С чего начать', href: '/getting-started/installation/' },
	{ label: 'Возможности', href: '/features/' },
	{ label: 'Примеры', href: '/examples/' },
	{ label: 'Архитектура', href: '/architecture/' },
];

const showTopNav = false;
---

<div class="header">
	<div class="title-wrapper sl-flex">
		<SiteTitle />
	</div>

	{
		showTopNav && (
			<nav class="top-nav" aria-label="Основная навигация">
				{navItems.map((item) => (
					<a href={item.href} class:list={{ active: Astro.url.pathname.startsWith(item.href) }}>
						{item.label}
					</a>
				))}
			</nav>
		)
	}

	<div class="search-wrapper sl-flex print:hidden">
		{shouldRenderSearch && <Search />}
	</div>

	<div class="sl-hidden md:sl-flex print:hidden right-group">
		<div class="sl-flex social-icons">
			<SocialIcons />
		</div>
		<ThemeSelect />
		<LanguageSelect />
	</div>
</div>

<style>
	@layer starlight.core {
		.header {
			display: flex;
			gap: var(--sl-nav-gap);
			align-items: center;
			height: 100%;
		}

		.title-wrapper {
			overflow: clip;
			padding: 0.25rem;
			margin: -0.25rem;
			min-width: 0;
			flex: 0 0 auto;
		}

		.top-nav {
			display: none;
			align-items: center;
			gap: 0.15rem;
			min-width: 0;
		}

		.top-nav a {
			display: inline-flex;
			align-items: center;
			min-height: 2rem;
			padding: 0 0.65rem;
			border-radius: 0.35rem;
			color: var(--sl-color-gray-2);
			font-size: 0.92rem;
			font-weight: 500;
			text-decoration: none;
			white-space: nowrap;
		}

		.top-nav a:hover,
		.top-nav a.active {
			background: var(--sl-color-gray-6);
			color: var(--sl-color-white);
		}

		.search-wrapper {
			justify-content: center;
			flex: 1 1 auto;
			min-width: 10rem;
		}

		.right-group,
		.social-icons {
			gap: 1rem;
			align-items: center;
		}

		.social-icons::after {
			content: '';
			height: 2rem;
			border-inline-end: 1px solid var(--sl-color-gray-5);
		}

		@media (min-width: 64rem) {
			.top-nav {
				display: flex;
			}
		}
	}
</style>
